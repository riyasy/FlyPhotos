            <RegistryValue Key="FileAssociations" Name=".pxn" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".raf" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".raw" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".rw2" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".rwl" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".sr2" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".srf" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".srw" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".x3f" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".dng" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".psd" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".svg" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".cin" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".dpx" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".exr" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".fits" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".hdr" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".pam" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".pbm" Type="string" Value="FlyPhotos.Image" />
            <RegistryValue Key="FileAssociations" Name=".pct" Type="string" Value="FlyPhotos.Image" />
