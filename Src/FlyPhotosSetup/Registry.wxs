            <RegistryValue Key="FileAssociations" Name=".ff" Type="string" Value="FlyPhotos.Image" />
          </RegistryKey>
        </RegistryKey>
      </Component>

      <!-- Right-click "Open with Fly" on all files - gated by the checkbox property. -->
      <Component Id="ContextMenuEntry" Guid="*" Condition="ADDCONTEXTMENU=1">
        <RegistryKey Root="HKCR" Key="*\shell\Open with Fly" ForceDeleteOnUninstall="yes">
          <RegistryValue Key="command" Type="string"
                         Value="&quot;[INSTALLFOLDER]FlyPhotos.exe&quot; &quot;%1&quot;" KeyPath="yes" />
          <RegistryValue Name="Icon" Type="string"
                         Value="&quot;[INSTALLFOLDER]Assets\app-icon.ico&quot;" />
        </RegistryKey>
      </Component>

    </ComponentGroup>
  </Fragment>
</Wix>
